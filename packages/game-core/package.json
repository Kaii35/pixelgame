{
  "name": "@pixelgame/game-core",
  "version": "0.1.0",
  "private": true,
  "description": "Pure domain logic: iso math, tilemaps, movement rules, pathfinding. No runtime deps.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@pixelgame/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@pixelgame/eslint-config": "workspace:*",
    "@pixelgame/ts-config": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
