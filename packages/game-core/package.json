{
  "name": "@pixelgame/game-core",
  "version": "0.1.0",
  "private": true,
  "description": "Pure domain logic: iso math, tilemaps, movement rules, pathfinding. No runtime deps.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./iso": "./src/iso/index.ts",
    "./tile": "./src/tile/index.ts",
    "./movement": "./src/movement/index.ts",
    "./pathfinding": "./src/pathfinding/index.ts",
    "./room": "./src/room/index.ts"
  },
  "scripts": {
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@pixelgame/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@pixelgame/eslint-config": "workspace:*",
    "@pixelgame/ts-config": "workspace:*",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
