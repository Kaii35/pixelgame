  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@pixelgame/eslint-config": "workspace:*",
    "@pixelgame/ts-config": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2"
  }
}
