{
  "name": "@pixelgame/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pixelgame React + Phaser client.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@pixelgame/game-core": "workspace:*",
    "@pixelgame/networking": "workspace:*",
    "@pixelgame/shared-types": "workspace:*",
    "@pixelgame/shared-ui": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "colyseus.js": "^0.16.0",
    "phaser": "^3.85.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@pixelgame/eslint-config": "workspace:*",
    "@pixelgame/ts-config": "workspace:*",
    "@types/react": "^18.3.7",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.1"
  }
}
