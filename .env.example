###############################################################################
#  PIXELGAME — Root .env (copy to .env and adjust)
#  Each app has its own .env.example; this file documents shared values.
###############################################################################

# --- Environment --------------------------------------------------------------
NODE_ENV=development

# --- Postgres ----------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pixelgame
POSTGRES_PASSWORD=pixelgame_dev_password
POSTGRES_DB=pixelgame
DATABASE_URL=postgresql://pixelgame:pixelgame_dev_password@localhost:5432/pixelgame?schema=public

# --- Redis -------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- JWT (RS256) -------------------------------------------------------------
# Run `pnpm run keys:generate` to produce PEM files in ./keys/
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=pixelgame
JWT_AUDIENCE=pixelgame-client

# --- API ---------------------------------------------------------------------
API_PORT=3001
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:5173

# --- Game Server --------------------------------------------------------------
GAME_SERVER_PORT=2567
GAME_SERVER_HOST=0.0.0.0

# --- Client ------------------------------------------------------------------
VITE_API_URL=http://localhost:3001
VITE_GAME_SERVER_URL=ws://localhost:2567
